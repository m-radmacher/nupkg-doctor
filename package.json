{
  "name": "nupkg-doctor",
  "version": "2.0.3",
  "main": "dist/index.js",
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "clean": "rimraf dist/",
    "lint": "biome ci src/",
    "lint:fix": "biome check --write src/",
    "package": "esbuild src/index.ts --bundle --platform=node --target=node24 --format=cjs --minify --outfile=dist/index.js --loader:.json=json",
    "p": "yarn delete && yarn build && yarn package"
  },
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/exec": "^3.0.0",
    "@aws-sdk/client-s3": "^3.1075.0",
    "archiver": "^8.0.0",
    "fast-xml-builder": "^1.2.0",
    "fast-xml-parser": "^5.9.3",
    "unzipper": "^0.12.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@types/archiver": "^8.0.0",
    "@types/node": "^26.0.1",
    "@types/unzipper": "^0.10.11",
    "esbuild": "^0.28.1",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b"
}
