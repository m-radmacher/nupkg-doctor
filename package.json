{
  "name": "nupkg-doctor",
  "version": "1.0.0",
  "main": "dist/index.js",
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "clean": "rimraf dist/",
    "lint": "biome ci src/",
    "lint:fix": "biome check --write src/",
    "package": "esbuild src/index.ts --bundle --platform=node --target=node24 --format=cjs --minify --outfile=dist/index.js --loader:.json=json",
    "p": "yarn delete && yarn build && yarn package"
  },
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/exec": "^3.0.0",
    "archiver": "^8.0.0",
    "extract-zip": "^2.0.1",
    "fast-xml-builder": "^1.2.0",
    "fast-xml-parser": "^5.9.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@types/archiver": "^8.0.0",
    "@types/node": "^26.0.1",
    "esbuild": "^0.28.1",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3"
  }
}
